<Window x:Class="WypozyczalniaRowerow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wypożyczalnia" Height="600" Width="600">

    <ScrollViewer>
        <StackPanel Margin="10">

            <GroupBox Header="Klienci" Margin="5">
                <StackPanel Margin="5">
                    <TextBlock Text="Imię"/>
                    <TextBox Text="{Binding Imie}" Margin="2"/>

                    <TextBlock Text="Nazwisko"/>
                    <TextBox Text="{Binding Nazwisko}" Margin="2"/>

                    <TextBlock Text="Telefon"/>
                    <TextBox Text="{Binding Telefon}" Margin="2"/>

                    <TextBlock Text="Email"/>
                    <TextBox Text="{Binding Email}" Margin="2"/>

                    <Button Content="Dodaj klienta" Margin="5" Command="{Binding DodajKlientaCommand}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Rowery" Margin="5">
                <StackPanel Margin="5">
                    <TextBlock Text="Marka"/>
                    <TextBox Text="{Binding Marka}" Margin="2"/>
                    
                    <TextBlock Text="Model"/>
                    <TextBox Text="{Binding Model}" Margin="2"/>

                    <TextBlock Text="Typ"/>
                    <TextBox Text="{Binding Typ}" Margin="2"/>

                    <TextBlock Text="Cena"/>
                    <TextBox Text="{Binding Cena}" Margin="2"/>

                    <Button Content="Dodaj rower" Margin="5" Command="{Binding DodajRowerCommand}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Wyszukiwanie" Margin="5">
                <StackPanel Margin="5">
                    <TextBlock Text="Nazwisko klienta"/>
                    <TextBox x:Name="txtSzukajKlienta" Margin="2"/>
                    <Button Content="Szukaj klienta" Margin="2" Click="SzukajKlienta_Click"/>

                    <TextBlock Text="Typ roweru"/>
                    <TextBox x:Name="txtSzukajRower" Margin="2"/>
                    <Button Content="Szukaj roweru" Margin="2" Click="SzukajRower_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Wypożyczenie" Margin="5">
                <StackPanel Margin="5">
                    <TextBlock Text="Id klienta"/>
                    <TextBox x:Name="txtIdKlienta" Margin="2"/>

                    <TextBlock Text="Id roweru"/>
                    <TextBox x:Name="txtIdRoweru" Margin="2"/>

                    <TextBlock Text="Ilość dni"/>
                    <TextBox x:Name="txtDni" Margin="2"/>

                    <Button Content="Wypożycz" Margin="5" Click="Wypozycz_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Wyniki" Margin="5">
                <ListBox ItemsSource="{Binding Wyniki}" Height="150"/>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>

</Window>